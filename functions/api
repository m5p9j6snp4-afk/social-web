// functions/api/user.js
import {Buffer} from 'node:buffer'
export async function onRequestPost({env,request}){
 let data=await request.json()
 const db=env.DB
 //註冊
 if(!request.url.includes("login")){
  try{
   await db.prepare("INSERT INTO user(username,password,nickname) VALUES(?,?,?)")
   .bind(data.username,data.password,data.nickname).run()
   return new Response("註冊成功")
  }catch{
   return new Response("帳號已存在",{status:400})
  }
 }
 //登入
 let u=await db.prepare("SELECT id,password FROM user WHERE username=?")
 .bind(data.username).first()
 if(!u||u.password!==data.password)return new Response("帳密錯誤",{status:400})
 //簡易token=用戶ID
 return new Response(String(u.id))
}